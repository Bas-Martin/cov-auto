@inject AuthService AuthService
@inject NavigationManager Navigation

<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-0 px-3">
    <a class="navbar-brand fw-bold" href="/">🔧 CovAuto</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navContent">
        <ul class="navbar-nav me-auto">
            <li class="nav-item">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" href="werkorders">Werkorders</NavLink>
            </li>
            <AuthorizeView Roles="Planner">
                <li class="nav-item">
                    <NavLink class="nav-link" href="teams">Teams</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="rapporten">Rapporten</NavLink>
                </li>
            </AuthorizeView>
        </ul>

        <AuthorizeView>
            <Authorized>
                <span class="navbar-text me-3 text-white">
                    👤 @context.User.Identity?.Name
                    <span class="badge bg-secondary ms-1">@context.User.FindFirst(ClaimTypes.Role)?.Value</span>
                </span>
                <button class="btn btn-outline-light btn-sm" @onclick="Logout">Uitloggen</button>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("login", forceLoad: false);
    }
}
