@page "/werkorders/{Id:int}"
@attribute [Authorize]
@inject WorkOrderApiService WorkOrderService

<PageTitle>Werkorder details – CovAuto</PageTitle>

@if (_loading)
{
    <div class="text-center py-4"><div class="spinner-border" role="status"></div></div>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_wo != null)
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="werkorders">Werkorders</a></li>
            <li class="breadcrumb-item active">@_wo.Title</li>
        </ol>
    </nav>

    <h2>@_wo.Title</h2>

    <div class="row g-3">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">📝 Details</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Beschrijving</dt>
                        <dd class="col-sm-8">@_wo.Description</dd>
                        <dt class="col-sm-4">Klant</dt>
                        <dd class="col-sm-8">@_wo.CustomerName</dd>
                        <dt class="col-sm-4">Adres</dt>
                        <dd class="col-sm-8">@_wo.Address</dd>
                        <dt class="col-sm-4">Aangemaakt op</dt>
                        <dd class="col-sm-8">@_wo.CreatedAt.ToString("dd-MM-yyyy HH:mm")</dd>
                        @if (_wo.ScheduledFor.HasValue)
                        {
                            <dt class="col-sm-4">Gepland voor</dt>
                            <dd class="col-sm-8">@_wo.ScheduledFor.Value.ToString("dd-MM-yyyy HH:mm")</dd>
                        }
                        <dt class="col-sm-4">Geschatte uren</dt>
                        <dd class="col-sm-8">@_wo.EstimatedHours u</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header">📊 Status & Prioriteit</div>
                <div class="card-body">
                    <p><strong>Status:</strong> <span class="badge bg-info text-dark">@_wo.Status</span></p>
                    <p><strong>Prioriteit:</strong> <span class="badge bg-warning text-dark">@_wo.Priority</span></p>
                    <p><strong>Team:</strong> @_wo.ServiceTeamName</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="werkorders" class="btn btn-secondary btn-sm">← Terug</a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private WorkOrderDto? _wo;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await WorkOrderService.GetWorkOrderAsync(Id);
            if (result?.Success == true)
                _wo = result.Data;
            else
                _error = result?.Message ?? "Werkorder niet gevonden.";
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 403)
        {
            _error = "U heeft geen toegang tot deze werkorder.";
        }
        catch (Exception ex)
        {
            _error = $"Fout: {ex.Message}";
        }
        finally { _loading = false; }
    }
}
